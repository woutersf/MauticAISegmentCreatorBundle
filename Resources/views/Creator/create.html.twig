{% extends '@MauticCore/Default/content.html.twig' %}

{% block mauticContent %}ai_segment_creator{% endblock %}

{% block headerTitle %}<i class="ri-sparkling-line"></i> Create Segment with AI{% endblock %}

{% block content %}
<div class="pa-md">

    {% if error %}
        <div class="alert alert-danger">
            <i class="ri-error-warning-line"></i> {{ error }}
        </div>
    {% endif %}

    {% if models is empty %}
        <div class="alert alert-warning">
            <i class="ri-settings-3-line"></i>
            <strong>AI Connection not configured.</strong>
            Please configure the <a href="{{ path('mautic_plugin_index') }}">AI Connection integration</a> first.
        </div>
    {% endif %}

    <div class="row">
        <div class="col-sm-8 col-sm-offset-2">
            <div class="panel panel-default">
                <div class="panel-body pa-lg">

                    <form method="post" action="{{ path('mautic_ai_segment_creator_create') }}" id="ai-segment-creator-form">

                        <div class="form-group">
                            <label for="ai_model" class="control-label">
                                <i class="ri-cpu-line"></i> AI Model
                            </label>
                            <select name="model" id="ai_model" class="form-control">
                                {% for displayName, modelId in models %}
                                    <option value="{{ modelId }}" {% if modelId == selectedModel %}selected{% endif %}>
                                        {{ displayName }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="ai_prompt" class="control-label">
                                <i class="ri-group-line"></i> Describe your target audience
                            </label>

                            <div class="well well-sm mb-sm" style="background: #f8f9fa; border-color: #e9ecef;">
                                <small class="text-muted">
                                    <strong>For best results, include:</strong>
                                    who you want to target &nbsp;·&nbsp;
                                    relevant contact fields (country, job title, score…) &nbsp;·&nbsp;
                                    behaviors (opened email X, visited page Y) &nbsp;·&nbsp;
                                    engagement level or recency
                                </small>
                            </div>

                            <textarea
                                name="prompt"
                                id="ai_prompt"
                                class="form-control"
                                rows="7"
                                placeholder="e.g. Contacts in Belgium or the Netherlands who have a high lead score (above 50), opened our last newsletter, and have not unsubscribed."
                                style="resize: vertical;"
                            >{{ prompt }}</textarea>

                            <div class="mt-sm">
                                <small class="text-muted mr-xs">Quick starts:</small>
                                <span class="label label-default js-suggestion" style="cursor:pointer; margin-right:4px;">High-value leads in Belgium</span>
                                <span class="label label-default js-suggestion" style="cursor:pointer; margin-right:4px;">Contacts who opened last newsletter</span>
                                <span class="label label-default js-suggestion" style="cursor:pointer; margin-right:4px;">Inactive contacts (no activity 90 days)</span>
                                <span class="label label-default js-suggestion" style="cursor:pointer; margin-right:4px;">Decision makers in enterprise</span>
                                <span class="label label-default js-suggestion" style="cursor:pointer;">New leads this month</span>
                            </div>
                        </div>

                        <div class="mt-lg">
                            <button type="submit" class="btn btn-primary btn-lg" id="ai-generate-btn" {% if models is empty %}disabled{% endif %}>
                                <i class="ri-sparkling-line"></i>
                                Generate Segment
                            </button>
                            <a href="{{ path('mautic_segment_index') }}" class="btn btn-default btn-lg ml-sm">
                                Cancel
                            </a>
                        </div>

                    </form>

                </div>
            </div>

            <p class="text-muted text-center small">
                <i class="ri-information-line"></i>
                The AI will analyse your available contact fields, emails and pages to build the most accurate filters.
                The segment is saved as an unpublished draft — review the filters in the editor before activating it.
            </p>
        </div>
    </div>

</div>

<div id="ai-loading-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(255,255,255,0.85); z-index:9999; align-items:center; justify-content:center; flex-direction:column;">
    <div style="text-align:center;">
        <i class="ri-sparkling-line" style="font-size:3rem; color:#4e5d6c; animation: pulse 1.5s ease-in-out infinite;"></i>
        <p style="margin-top:16px; font-size:1.1rem; color:#4e5d6c; font-weight:500;">Building your segment…</p>
        <p class="text-muted small">Analysing fields and generating filters</p>
    </div>
</div>

<style>
@keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(1.2); }
}
</style>

<script>
(function () {
    document.querySelectorAll('.js-suggestion').forEach(function (el) {
        el.addEventListener('click', function () {
            document.getElementById('ai_prompt').value = this.textContent.trim();
            document.getElementById('ai_prompt').focus();
        });
    });

    var form    = document.getElementById('ai-segment-creator-form');
    var overlay = document.getElementById('ai-loading-overlay');
    var btn     = document.getElementById('ai-generate-btn');
    form.addEventListener('submit', function () {
        if (document.getElementById('ai_prompt').value.trim() !== '') {
            overlay.style.display = 'flex';
            btn.disabled = true;
        }
    });
}());
</script>
{% endblock %}
